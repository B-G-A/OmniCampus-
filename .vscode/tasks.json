{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start React Frontend",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "group": "omnicampus",
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Node Backend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/omnicampus-backend/node-server"
      },
      "presentation": {
        "group": "omnicampus",
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Python AI Service",
      "type": "shell",
      "command": ".\\venv\\Scripts\\python.exe -m uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
      "options": {
        "cwd": "${workspaceFolder}/omnicampus-backend/python-ai-service"
      },
      "presentation": {
        "group": "omnicampus",
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Run All OmniCampus Services",
      "dependsOn": [
        "Start React Frontend",
        "Start Node Backend",
        "Start Python AI Service"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
